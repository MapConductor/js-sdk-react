{
  "name": "@mapconductor/js-sdk-react",
  "version": "0.1.0",
  "description": "React bindings for MapConductor SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.ts",
        "import": "./dist/index.native.mjs",
        "require": "./dist/index.native.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/index.native.d.ts",
      "import": "./dist/index.native.mjs",
      "require": "./dist/index.native.js"
    }
  },
  "files": [
    "android",
    "ios",
    "MapConductorReactNativeCore.podspec",
    "react-native.config.js",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/index.native.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/index.native.ts --format cjs,esm --watch",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "keywords": ["maps", "typescript", "react"],
  "author": "MapConductor",
  "license": "Apache2",
  "dependencies": {
    "@mapconductor/js-sdk-core": "0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
